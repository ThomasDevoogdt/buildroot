#!/bin/sh

export LIBVA_DRIVERS_PATH="/usr/lib/dri"

PIDFILE="/var/run/mpv.pid"
SOCAT_PID="/var/run/mpv-socat.pid"
MPV_SOCK="/tmp/mpv.sock"
MPV_PORT=6600

# Prefer HDMI-A-1 if connected, fall back to any available connector
pick_connector() {
	if [ "$(cat /sys/class/drm/card0-HDMI-A-1/status 2>/dev/null)" = "connected" ]; then
		echo "HDMI-A-1"
	else
		echo ""
	fi
}

case "$1" in
start)
	printf "Starting mpv: "

	# Unmute and set max volume on analog audio (card 1 - Realtek ALC236)
	alsactl init 1 >/dev/null 2>&1
	if command -v amixer >/dev/null 2>&1; then
		amixer -c1 sset 'Headphone' 100% unmute >/dev/null 2>&1
		amixer -c1 sset 'Speaker' 100% unmute >/dev/null 2>&1
	fi
	rm -f "$MPV_SOCK"

	CONN=$(pick_connector)
	DRM_CONN=""
	[ -n "$CONN" ] && DRM_CONN="--drm-connector=$CONN"
	start-stop-daemon -S -b -m -p "$PIDFILE" -x /bin/sh -- -c \
		"exec setsid mpv \
	  --input-ipc-server=$MPV_SOCK \
	  --vo=gpu --gpu-context=drm \
	  $DRM_CONN \
	  --hwdec=vaapi \
	  --ao=alsa --audio-device=alsa/plughw:1,0 \
	  --idle=yes \
	  --force-window=yes \
	  --background-color=000000 \
	  --profile=low-latency \
	  --video-sync=audio \
	  --really-quiet \
	  </dev/tty1 >/dev/null 2>&1"

	# Wait for mpv to create the socket
	sleep 1

	# Expose IPC over TCP so the controller can connect directly
	start-stop-daemon -S -b -m -p "$SOCAT_PID" -x /usr/bin/socat -- \
		TCP-LISTEN:${MPV_PORT},fork,reuseaddr UNIX-CONNECT:${MPV_SOCK}

	echo "OK"
	;;
stop)
	printf "Stopping mpv: "
	start-stop-daemon -K -p "$SOCAT_PID" -s TERM 2>/dev/null
	start-stop-daemon -K -p "$PIDFILE" -s TERM
	rm -f "$PIDFILE" "$SOCAT_PID" "$MPV_SOCK"
	echo "OK"
	;;
restart)
	$0 stop
	sleep 1
	$0 start
	;;
*)
	echo "Usage: $0 {start|stop|restart}"
	exit 1
	;;
esac
