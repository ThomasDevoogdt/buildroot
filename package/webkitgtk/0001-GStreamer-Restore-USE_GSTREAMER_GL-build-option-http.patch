     list(APPEND WebCore_SYSTEM_INCLUDE_DIRECTORIES
-        ${GSTREAMER_GL_INCLUDE_DIRS}
         ${GSTREAMER_TAG_INCLUDE_DIRS}
         ${GSTREAMER_VIDEO_INCLUDE_DIRS}
     )
 
     if (NOT USE_GSTREAMER_FULL)
         list(APPEND WebCore_LIBRARIES
